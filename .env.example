# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── JWT (generate a long random secret) ─────────────────────────────────────
# openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-at-least-64-chars-long

# ─── Groq (AI content generation) ──────────────────────────────────────────────
# Get from https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Optional — defaults to llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── Paddle (billing) ──────────────────────────────────────────────────────────
# Get from Paddle Dashboard → Developer tools → Authentication
PADDLE_API_KEY=pdl_live_apikey_...
# sandbox or production (auto-detected from live/sandbox key if omitted)
# PADDLE_ENVIRONMENT=production
# Webhook secret from Developer tools → Notifications → your destination
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
# Price IDs from Catalog → your Pro/Business prices (pri_...)
PADDLE_PAID_PLAN_PRICE_ID=pri_...
PADDLE_BUSINESS_PLAN_PRICE_ID=pri_...
# Default payment link page (must include Paddle.js) — used when checkout.url is empty
PADDLE_DEFAULT_PAYMENT_LINK=https://yourdomain.com/checkout

# ─── Email (optional — for transactional emails via Resend) ──────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com
