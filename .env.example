# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── JWT (generate a long random secret) ─────────────────────────────────────
# openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-at-least-64-chars-long

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys (use TEST keys for dev)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret from Stripe CLI or Dashboard (Webhooks section)
STRIPE_WEBHOOK_SECRET=whsec_...
# The price ID of your paid plan product in Stripe
STRIPE_PAID_PLAN_PRICE_ID=price_...

# ─── Email (optional — for transactional emails via Resend) ──────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com
